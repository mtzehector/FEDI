    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>3.1</version>
                <configuration>
                    <source>1.8</source>
                    <target>1.8</target>
                    <encoding>${project.build.sourceEncoding}</encoding>
                    <compilerArguments>
                        <endorseddirs>${endorsed.dir}</endorseddirs>
                    </compilerArguments>
                    <showDeprecation>true</showDeprecation>
                </configuration>
            </plugin>

            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-war-plugin</artifactId>
                <version>2.4</version>
                <configuration>
                    <failOnMissingWebXml>false</failOnMissingWebXml>
                    <filteringDeploymentDescriptors>true</filteringDeploymentDescriptors>
                </configuration>
            </plugin>

            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-dependency-plugin</artifactId>
                <version>2.8</version>
                <executions>
                    <execution>
                        <phase>validate</phase>
                        <goals>
                            <goal>copy</goal>
                        </goals>
                        <configuration>
                            <outputDirectory>${endorsed.dir}</outputDirectory>
                            <silent>true</silent>
                            <artifactItems>
                                <artifactItem>
                                    <groupId>javax</groupId>
                                    <artifactId>javaee-endorsed-api</artifactId>
                                    <version>6.0</version>
                                    <type>jar</type>
                                </artifactItem>
                            </artifactItems>
                        </configuration>
                    </execution>
                </executions>
            </plugin>

            <!-- Plugin para Generar Reportes -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-site-plugin</artifactId>
                <version>3.3</version>
            </plugin>

            <!-- Plugin para soportar la escritura de propiedades de acuerdo al profile seleccionado -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-resources-plugin</artifactId>
                <version>2.6</version>
                <configuration>
                    <encoding>${project.build.sourceEncoding}</encoding>
                </configuration>
            </plugin>
        </plugins>

        <resources>
            <resource>
                <directory>src/main/resources</directory>
                <filtering>true</filtering>
                <includes>
                    <include>**/*.xml</include>
                    <include>**/*.properties</include>
                </includes>
            </resource>
            <resource>
                <directory>src/main/resources</directory>
                <filtering>false</filtering>
                <excludes>
                    <exclude>**/*.xml</exclude>
                    <exclude>**/*.properties</exclude>
                </excludes>
            </resource>
        </resources>
    </build>

    <reporting>
        <plugins>
            <!-- Crea una copia del cÃ³digo fuente para los reportes -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-jxr-plugin</artifactId>
                <version>2.3</version>
            </plugin>

            <!-- Control de versiones -->
            <!-- Descomentar sÃ³lo si se tiene configurada la secciÃ³n de scm del proyecto -->
            <!--            <plugin>
                <groupId>net.sf</groupId>
                <artifactId>stat-scm</artifactId>
                <version>1.2.0</version>
            </plugin>-->

            <!-- Genera reportes de "Site" indicados -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-project-info-reports-plugin</artifactId>
                <version>2.7</version>
                <reportSets>
                    <reportSet>
                        <reports>
                            <report>index</report>
                            <report>issue-tracking</report>
                            <report>plugins</report>
                            <report>cim</report>
                            <report>license</report>
                            <report>mailing-list</report>
                            <report>project-team</report>
                            <report>plugin-management</report>
                            <report>summary</report>
                            <report>project-team</report>
                            <report>dependency-management</report>
                            <report>distribution-management</report>
                        </reports>
                    </reportSet>
                </reportSets>
            </plugin>

            <!-- Genera reporte que Revisa cobertura de pruebas unitarias -->
            <plugin>
                <groupId>org.codehaus.mojo</groupId>
                <artifactId>cobertura-maven-plugin</artifactId>
                <version>2.6</version>

                <configuration>
                    <instrumentation>
                        <ignores>
                            <ignore>arquitecturas.prototype.mjs.model.*</ignore>
                            <ignore>arquitecturas.prototype.mjs.persistence.*</ignore>
                            <ignore>arquitecturas.prototype.mjs.typehandler.*</ignore>
                            <ignore>fedi.ift.org.mx.arq.core.enums.*</ignore>
                            <ignore>fedi.ift.org.mx.arq.core.model.*</ignore>
                            <ignore>fedi.ift.org.mx.arq.core.persistence.*</ignore>
                        </ignores>
                        <excludes>
                            <exclude>arq/core/prototype.mjs/**/*Test.class</exclude>
                            <exclude>arq/core/prototype.mjs/model/*.class</exclude>
                            <exclude>arq/core/prototype.mjs/persistence/*.class</exclude>
                            <exclude>arq/core/prototype.mjs/typehandler/*.class</exclude>
                            <exclude>arq/core/prototype.mjs/exposition/*.class</exclude>
                            <exclude>arq/core/enums/*.class</exclude>
                            <exclude>arq/core/model/*.class</exclude>
                            <exclude>arq/core/persistence/*.class</exclude>
                        </excludes>
                    </instrumentation>
                </configuration>
            </plugin>

            <!-- RevisiÃ³n de codigo repetido o no usado -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-pmd-plugin</artifactId>
                <version>3.0.1</version>
                <configuration>
                    <targetJdk>1.6</targetJdk>
                </configuration>
            </plugin>

            <!-- JavaDoc -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-javadoc-plugin</artifactId>
                <version>2.9.1</version>
                <configuration>
                    <show>private</show>
                    <nohelp>true</nohelp>
                </configuration>
            </plugin>

            <!-- Genera reporte que Revisa el estilo -->
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-checkstyle-plugin</artifactId>
                <version>2.7</version>
                <configuration>
                    <configLocation>src/main/config/custom_checks.xml</configLocation>
                </configuration>
                <!-- ConfiguraciÃ³n para la nueva versiÃ³n -->
                <!--<version>2.10</version>
                <configuration>
                    <configLocation>src/main/config/sun_custom_checks.xml</configLocation>
                </configuration>-->
            </plugin>

            <!-- Busca bugs en el código -->
            <plugin>
                <groupId>org.codehaus.mojo</groupId>
                <artifactId>findbugs-maven-plugin</artifactId>
                <version>2.5.2</version>
                <configuration>
                    <excludeFilterFile>src/main/config/bugFilter.xml</excludeFilterFile>
                </configuration>
            </plugin>

            <!-- Contador de líneas de código -->
            <plugin>
                <groupId>org.codehaus.mojo</groupId>
                <artifactId>javancss-maven-plugin</artifactId>
                <version>2.0</version>
            </plugin>
        </plugins>
    </reporting>

    <repositories>
        <repository>
            <id>java-jwt</id>
            <name>java jwt</name>
            <url>https://mvnrepository.com/artifact/com.auth0/java-jwt</url>
        </repository>
        <repository>
            <url>http://repository.primefaces.org/</url>
            <id>PrimeFaces-maven-lib</id>
            <layout>default</layout>
            <name>Repository for library PrimeFaces-maven-lib</name>
        </repository>
        <repository>
            <id>jasperreports-repo</id>
            <name>JasperReports Repository</name>
            <url>http://jasperreports.sourceforge.net/maven2</url>
        </repository>
        <repository>
            <id>wso2-maven2-repository</id>
            <url>http://dist.wso2.org/maven2/</url>
        </repository>
        <repository>
            <id>apache-maven2-repo</id>
            <name>Apache Maven2 Repository</name>
            <url>http://repo1.maven.org/maven2/</url>
        </repository>
    </repositories>

    <profiles>
        <profile>
            <id>development-oracle1</id>
             <activation>
                <activeByDefault>true</activeByDefault>
            </activation>
            <properties>
                <!-- Nombre del profile en tiempo de ejecuciÃ³n para spring -->
                <profileName>development-oracle1</profileName>
                <!-- Base de datos -->
                <profile.jdbc.driverClassName>oracle.jdbc.OracleDriver</profile.jdbc.driverClassName>
                <profile.jdbc.url>CADENA</profile.jdbc.url>
                <profile.jdbc.username>CADENA</profile.jdbc.username>
                <profile.jdbc.password>AAAAAAAAAAAAAAAAAAAA</profile.jdbc.password>
                <profile.jdbc.jndi>jdbc</profile.jdbc.jndi>
                <!-- MyBatis XML location -->
                <profile.myBatis.xml.location>myBatis/oracle/**/*.xml</profile.myBatis.xml.location>
                <!-- Correo -->
                <profile.mail.active>false</profile.mail.active>
                <profile.mail.debug>true</profile.mail.debug>
                <!-- URL del servidor incluyendo el contexto -->
                <profile.mail.url>http://127.0.0.1:8080/prototype.mjs</profile.mail.url>
                <!-- Modo del captcha -->
                <profile.captcha.debug.mode>false</profile.captcha.debug.mode>
                <!-- AplicaciÃ³n en modo light -->
                <profile.app.mode.light>false</profile.app.mode.light>
                <!-- Mensajes en bitÃ¡cora -->
                <profile.log4j.rootLogger>info, stdout, file</profile.log4j.rootLogger>
                <profile.log4j.file>BitacoraFEDIPortalWeb</profile.log4j.file>
                <!-- Renderado del growl global -->
                <profile.render.gobal.growl>true</profile.render.gobal.growl>
                <profile.version.app>DEV:20260214-1</profile.version.app>
                <profile.reporte.url>http://svmpegasoclonds/ReportServer/Pages/ReportViewer.aspx?%2fPRUEBAS_DES%2f</profile.reporte.url>
